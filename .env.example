# =============================================================
# Diário da Guilda — variáveis de ambiente
# Copie para .env.local e preencha conforme necessário.
# =============================================================

# --- Firestore (Firebase Admin SDK) ---
# Se estas NÃO estiverem definidas, o app usa um adapter in-memory
# com os dados de exemplo (útil para desenvolvimento das Fases 1-3).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# A chave privada vem com quebras de linha \n — manter como uma única
# linha com \n literais; o app faz o parse automaticamente.
FIREBASE_PRIVATE_KEY=

# --- Vínculo hardcoded master -> guild (fase atual) ---
MASTER_GUILD_ID=guild-aurora

# --- Autenticação do Master (Fase 4) ---
# Senha de login do Mestre (texto puro, comparada em tempo constante).
MASTER_PASSWORD=
# Segredo para assinar o JWT de sessão (HS256). Gere com:
#   openssl rand -hex 32
JWT_SECRET=

# --- Deploy / Publicação (Fase 5) ---
DEPLOY_HOOK_URL=

# --- MCP (Fase 6) ---
# Token de serviço para as ESCRITAS via MCP (createSession/updateSession).
# Gere com: openssl rand -hex 32
# O cliente envia em: header "Authorization: Bearer <token>", query "?token=<token>"
# ou na rota "/api/mcp/<token>". Leitura é liberada sem token.
MCP_SERVICE_TOKEN=
